{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BOOM | Cultura para crescimento",
  "colors": {
    "primary": "#ff5a52",
    "light": "#ff7a74",
    "dark": "#1b0d25"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Início",
        "groups": [
          {
            "group": "Bem-vindo",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Cultura & Metodologia",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Conteúdo",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/components",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "Ferramentas",
            "pages": [
              "agent-ready/prompt",
              "agent-ready/visibility",
              "agent-ready/contextual",
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Documentação da API",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Exemplos",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Wiki BOOM",
          "href": "https://wiki.suaboom.com.br",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://blog.suaboom.com.br",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/BOOM__01-LOGOTIPO_HORIZONTAL_AMARELO.jpg",
    "dark": "/logo/BOOM__01-LOGOTIPO_HORIZONTAL_BEGE.jpg"
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:contato@suaboom.com.br",
        "label": "Suporte"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Plataforma",
      "href": "https://app.suaboom.com.br"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
    "claude"
  ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/boom",
      "instagram": "https://instagram.com/suaboom"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {}
}
