{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "BOOM | Cultura para crescimento",
  "colors": {
    "primary": "#ff5a52",
    "light": "#ff7a74",
    "dark": "#1b0d25"
  },
  "favicon": "/favicon-boom.svg",
  "logo": {
    "light": "/logo/BOOM__01-LOGOTIPO_HORIZONTAL_CORAL.png",
    "dark": "/logo/BOOM__01-LOGOTIPO_HORIZONTAL_CORAL.png"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "light": "#fffff3",
    "dark": "#1b0d25"
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:contato@suaboom.com.br",
        "label": "Suporte"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Plataforma",
      "href": "https://app.suaboom.com.br"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/boom",
      "instagram": "https://instagram.com/suaboom"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"],
    "display": "header"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Início",
        "groups": [
          {
            "group": "Bem-vindo",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Metodologia",
            "pages": [
              "metodologia/tese-de-cultura",
              "metodologia/convergencia-cultural",
              "metodologia/cultura-vs-resultados",
              "metodologia/cultura-vs-resultados-indicador",
              "metodologia/defensores-e-ofensores",
              "metodologia/engajamento",
              "metodologia/gap-da-lideranca"
            ]
          },
          {
            "group": "GPS de Cultura",
            "pages": [
              "gps/faq-gps",
              "gps/index-de-cultura-e-scores",
              "gps/tracos"
            ]
          },
          {
            "group": "Módulos",
            "pages": [
              "modulos/visao-geral",
              "modulos/modulo-01-parte-01",
              "modulos/modulo-01-parte-02",
              "modulos/modulo-01-parte-03"
            ]
          },
          {
            "group": "Ferramentas",
            "pages": [
              "agent-ready/prompt",
              "agent-ready/visibility",
              "agent-ready/contextual",
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Documentação da API",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Exemplos",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Wiki BOOM",
          "href": "https://wiki.suaboom.com.br",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://blog.suaboom.com.br",
          "icon": "newspaper"
        }
      ]
    }
  }
}
